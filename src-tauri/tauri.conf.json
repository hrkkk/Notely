{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Notely",
  "version": "0.1.0",
  "identifier": "com.notely.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Notely",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "maximized": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "icon": ["icons/icon.png", "icons/icon.ico"]
  }
}
